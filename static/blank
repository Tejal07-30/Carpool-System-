@api_view(['GET'])
def driverrequests(request):
    tripid = request.GET.get('tripid')
    print("ALL REQUESTS:", list(CarpoolRequest.objects.all()))
    print("PENDING REQUESTS:", list(CarpoolRequest.objects.filter(status='pending')))
    if tripid:
        try:
            trip = Trip.objects.get(id=tripid)
        except Trip.DoesNotExist:
            return render(request, "driver/requests.html", {"requests": []})
    else:
        try:
            trip = Trip.objects.filter(driver=request.user, status='active').first()
        except Trip.DoesNotExist:
            return render(request, "driver/requests.html", {"requests": []})

    requests = CarpoolRequest.objects.filter(status='pending')

    data = []

    for req in requests:
        matchingtrips = findmatchingtrips(req.pickupnode, req.dropoffnode)

        if trip in matchingtrips:
            faredata = calculatefare(trip, req.pickupnode, req.dropoffnode)

            data.append({
                'requestid': req.id,
                'passenger': req.passenger.username,
                'pickup': req.pickupnode.name,
                'drop': req.dropoffnode.name,
                'fare': faredata['fare'],
                'detour': faredata['detour']
            })

    return render(request, "driver/requests.html", {
        "requests": data
    })